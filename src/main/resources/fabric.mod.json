  "environment": "*",
  "entrypoints": {
    "main": [
      "me.rogerwindberg.dupeplayerblock.DupePlayerBlockMod"
    ]
  },
  "mixins": [
    "dupeplayerblock.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": ">=1.21.5"
  }
}
